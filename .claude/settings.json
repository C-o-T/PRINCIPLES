{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell",
            "args": ["-ExecutionPolicy", "Bypass", "-File", ".claude/hooks/session-start.ps1"]
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell",
            "args": ["-ExecutionPolicy", "Bypass", "-File", ".claude/hooks/check-sentinel.ps1"]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell",
            "args": ["-ExecutionPolicy", "Bypass", "-File", ".claude/hooks/check-principle-files.ps1"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell",
            "args": ["-ExecutionPolicy", "Bypass", "-File", ".claude/hooks/tool-logger.ps1"]
          }
        ]
      }
    ]
  }
}
